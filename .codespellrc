[codespell]
skip = *.json,*.bin,*.lock,./target,./.git,./node_modules,./pkg,./crates/aetheris-client-wasm/proto
ignore-words-list = aetheris,bevy,serde,quinn,wasm,paseto,p3,p1,p0,otlp,promql,logql,statics,unsecure,crate,lod,implementors,implementers,implementer,implementor,lode,ore
quiet-level = 2
check-filenames =
check-hidden =
